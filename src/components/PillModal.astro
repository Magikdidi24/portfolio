<div id="pill-modal-container" class="fixed z-[9999]">
  <button 
    id="pill-modal-trigger" 
    data-pill-trigger
    class="fixed bottom-8 right-8 bg-green-500/20 text-green-400 p-4 rounded-full hover:bg-green-500/40 z-50 border border-green-500/30 transition-all duration-300 transform hover:scale-110 shadow-lg shadow-green-500/20 hover:shadow-green-500/40 group"
    aria-label="Choose your path"
  >
    <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 group-hover:animate-pulse" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z" />
      <path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3" />
      <line x1="12" y1="17" x2="12.01" y2="17" />
    </svg>
    <span class="absolute -top-1 -right-1 bg-red-500 text-white text-[10px] font-bold px-1.5 py-0.5 rounded-full animate-bounce">?</span>
  </button>
</div>
