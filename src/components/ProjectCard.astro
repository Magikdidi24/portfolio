---
// Unified ProjectCard — handles both image and video covers, optional link
interface Props {
  project: import("astro:content").CollectionEntry<"projects"> | import("astro:content").CollectionEntry<"personalProjects">;
}
const { data } = Astro.props.project;
const isVideo = data.cover.endsWith('.mp4') || data.cover.endsWith('.webm');
---
<article
  class="bg-black/80 border border-green-500/40 rounded-2xl shadow-lg overflow-hidden transition-all duration-300 hover:shadow-green-500/30 hover:shadow-xl hover:border-green-500/70 hover:-translate-y-1 group"
  data-matrix
>
  {isVideo ? (
    <video
      src={data.cover}
      class="w-full h-60 object-cover"
      autoplay
      muted
      loop
      playsinline
      preload="none"
    />
  ) : (
    <img
      src={data.cover}
      alt={`Cover of ${data.title}`}
      class="w-full h-60 object-cover"
      loading="lazy"
      decoding="async"
    />
  )}
  <div class="px-6 pt-4 pb-6">
    <!-- Title -->
    <h2 class="text-green-300 text-2xl font-semibold mb-2 group-hover:text-green-200 transition-colors">{data.title}</h2>

    <!-- Description -->
    <p class="text-green-300/80 mb-4 font-mono text-sm leading-relaxed">
      {data.description}
    </p>

    <!-- Team / Duration info -->
    <div class="flex items-center text-sm text-green-400 mb-4 gap-4 font-mono">
      <span class="flex items-center gap-1">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
            d="M17 20h5v-2a4 4 0 00-5-4m-4 4H4v-2a4 4 0 015-4m2 4a4 4 0 100-8 4 4 0 000 8z" />
        </svg>
        {data.teamSize} {data.teamSize > 1 ? 'people' : 'person'}
      </span>
      <span class="flex items-center gap-1">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <circle cx="12" cy="12" r="10" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6l4 2" />
        </svg>
        {data.timeAvailable}
      </span>
    </div>

    <!-- Stack -->
    <div class="flex flex-wrap gap-2 mb-4">
      {data.stack.map((tech: string) => (
        <span
          class="bg-green-900/50 text-green-400 px-3 py-1 rounded-full text-xs border border-green-500/30 font-mono transition-all duration-200 hover:bg-green-800/50 hover:border-green-400/50"
        >
          {tech}
        </span>
      ))}
    </div>

    <!-- Link button (only if link exists) -->
    {data.link && (
      <a
        href={data.link}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-block px-4 py-2 text-sm font-mono border border-green-500 text-green-400 hover:bg-green-500/10 rounded transition-colors duration-200"
      >
        View code →
      </a>
    )}
  </div>
</article>
