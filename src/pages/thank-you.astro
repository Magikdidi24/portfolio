---
import BaseLayout from '../layout/BaseLayout.astro';
const base = import.meta.env.BASE_URL;
---
<BaseLayout title="Thank you!">
  <section class="bg-black/70 backdrop-blur-sm p-12 rounded-lg border border-green-500/60 shadow-lg shadow-green-500/30 text-center max-w-lg mx-auto my-32">
    <h1 class="text-4xl font-mono text-green-400 mb-4">Thank you for your message!</h1>
    <p class="text-lg text-green-200 mb-6">
      I'll get back to you shortly.
    </p>
    <a
      href={base}
      class="font-mono text-green-400 border border-green-500/60 px-6 py-3 rounded-full hover:bg-green-500/10 transition-all duration-300"
    >
      ← Back to home
    </a>
  </section>
</BaseLayout>
